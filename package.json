{
  "name": "fractions",
  "private": true,
  "version": "1.0.0",
  "description": "A fraction calculator",
  "keywords": [
    "fraction",
    "calculator"
  ],
  "author": "Rodrigo Jordao <rodrigo.jordao@gmail.com>",
  "license": "MIT",
  "scripts": {
    "generate-parser": "peggy --format es -o src/fractions-peg-parser.js src/fractions-peg-parser.pegjs",
    "dev": "npm run generate-parser && vite",
    "build": "npm run generate-parser && vite build",
    "preview": "vite preview",
    "test": "npm run generate-parser && vitest run"
  },
  "dependencies": {
    "katex": "^0.16.28"
  },
  "devDependencies": {
    "peggy": "^5.0.6",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
